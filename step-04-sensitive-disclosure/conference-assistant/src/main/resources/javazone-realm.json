{
  "realm": "quarkus",
  "enabled": true,
  "sslRequired": "external",
  "registrationAllowed": false,
  "clients": [
    {
      "clientId": "quarkus-app",
      "enabled": true,
      "publicClient": true,
      "redirectUris": ["*"],
      "webOrigins": ["*"],
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "defaultClientScopes": [
        "basic",
        "profile",
        "email",
        "roles",
        "web-origins",
        "attendee"
      ]
    },
    {
      "clientId": "conference-mcp",
      "enabled": true,
      "bearerOnly": true,
      "protocol": "openid-connect",
      "publicClient": false
    }
  ],
  "roles": {
    "realm": [
      { "name": "attendee" },
      { "name": "organizer" }
    ]
  },
  "clientScopes": [
    {
      "name": "attendee",
      "description": "Grants the conference-mcp audience so the token can be used at the MCP endpoint",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "false"
      },
      "protocolMappers": [
        {
          "name": "conference-mcp audience",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.client.audience": "conference-mcp",
            "access.token.claim": "true",
            "id.token.claim": "false",
            "introspection.token.claim": "true"
          }
        }
      ]
    }
  ],
  "users": [
    {
      "username": "alice",
      "enabled": true,
      "credentials": [{ "type": "password", "value": "alice", "temporary": false }],
      "realmRoles": ["attendee"]
    },
    {
      "username": "bob",
      "enabled": true,
      "credentials": [{ "type": "password", "value": "bob", "temporary": false }],
      "realmRoles": ["organizer", "attendee"]
    },
    {
      "username": "carol",
      "enabled": true,
      "credentials": [{ "type": "password", "value": "carol", "temporary": false }],
      "realmRoles": ["attendee"]
    },
    {
      "username": "dave",
      "enabled": true,
      "credentials": [{ "type": "password", "value": "dave", "temporary": false }],
      "realmRoles": ["attendee"]
    }
  ]
}
